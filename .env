# Noon Fleet HRMS — Local Development Configuration
# This file is for local/dev testing only
# For Render production, set variables in Render Dashboard

# Server
PORT=3000
SUPER_ADMIN_EMAIL=mauradhi@noon.com
SUPER_ADMIN_NAME=Super Admin

# Database: Leave empty for SQLite (local dev)
# For production, use PostgreSQL on Render
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Email: Leave commented out for DEV MODE (OTP prints to console)
# For real email, set these (Gmail SMTP example):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM="Noon Fleet HRMS" <your-email@gmail.com>
# HR_NOTIFY_EMAIL=your-email@gmail.com

# Google Drive (optional)
# GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json
# DRIVE_FOLDER_ID=your-folder-id

# Backup time (optional, cron format)
# BACKUP_CRON=0 3 * * *
